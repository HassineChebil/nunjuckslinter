{
  "name": "nunjucklinter",
  "version": "1.1.0",
  "description": "A linter for nunjuck templating engines",
  "main": "dist/index.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "lint": "njklint src/templates",
    "test": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "author": "Hassine Chebil",
  "license": "MIT",
  "type": "module",
  "bin": {
    "njklint": "./dist/index.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/HassineChebil/nunjuckslinter.git"
  },
  "keywords": [
    "nunjucks",
    "linter",
    "template",
    "static-analysis",
    "code-quality"
  ],
  "devDependencies": {
    "@types/node": "^22.10.10",
    "@vitest/coverage-v8": "^3.0.5",
    "biome": "^0.2.2",
    "typescript": "^5.7.3",
    "vite": "^6.0.11",
    "vitest": "^3.0.5"
  },
  "dependencies": {
    "chalk": "^5.4.1",
    "glob": "^11.0.1"
  },
  "volta": {
    "node": "22.13.1"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ]
}
